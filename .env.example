# Figma Design Director — external data/research tools (all optional; pluggable).
# Copy to .env and fill the keys you have. Without a key, the agent falls back:
#   crawl_site        -> extract_site (Playwright)
#   research_competitors -> built-in Reference Engine

# Firecrawl — robust crawl/scrape of JS-heavy pages into clean markdown.
# https://firecrawl.dev  (dashboard -> API key)
FIRECRAWL_API_KEY=

# Exa AI Search — neural/semantic web search for competitor research + best-practice sources.
# https://exa.ai  (dashboard -> API key)
EXA_API_KEY=

# BrightData — unblock Cloudflare/anti-bot sites (e.g. andaazfashion.com). Use ONE of:
#   Scraping Browser (CDP endpoint, recommended for blocked sites):
BRIGHTDATA_BROWSER_WSS=
#   or a proxy URL:  http://USER:PASS@brd.superproxy.io:22225
BRIGHTDATA_PROXY=

# Figma export bridge (reuse a mature MCP; not built here). One of:
#   a stdio command for a plugin-bridge MCP (e.g. cursor-talk-to-figma-mcp), or
#   the official Figma Dev Mode MCP URL. See README.
FIGMA_MCP_COMMAND=
FIGMA_MCP_URL=
